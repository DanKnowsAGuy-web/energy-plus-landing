---
import BiomarkerField from './BiomarkerField.astro';
---

<section class="hero" id="main">
  <div class="hero__field" aria-hidden="true">
    <BiomarkerField />
  </div>
  <div class="hero__veil" aria-hidden="true"></div>

  <div class="container hero__inner">
    <div class="hero__copy">
      <p class="eyebrow" data-reveal>GLP-1, guided by your own biology</p>

      <h1 class="hero__title" data-reveal style="--reveal-delay: 0.06s">
        Get more from GLP-1, <span class="hero__accent">with less of the guesswork.</span><sup class="hero__fn"><a href="#disclaimer" aria-label="Read important disclaimer">1</a></sup>
      </h1>

      <p class="lede hero__lede" data-reveal style="--reveal-delay: 0.14s">
        Most people start GLP-1 medications without knowing how their own body will respond.
        We read 150+ functional biomarkers and the genetics that matter first, then help your
        clinician personalize your plan, so you can pursue your goals while watching for the
        side effects people worry about.
      </p>

      <div class="hero__actions" data-reveal style="--reveal-delay: 0.22s">
        <a href="#enroll" class="btn">Get your protocol<span class="arrow" aria-hidden="true">→</span></a>
        <a href="#how" class="btn btn-ghost">See how it works</a>
      </div>

      <ul class="hero__trust" data-reveal style="--reveal-delay: 0.3s">
        <li>No lab visit</li>
        <li>Results in ~10–14 days</li>
        <li>Your data is never sold</li>
      </ul>
    </div>
  </div>

  <a href="#what" class="hero__scroll" aria-label="Scroll to learn more">
    <span></span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: min(94svh, 880px);
    display: flex; align-items: center;
    padding-block: var(--sp-8) var(--sp-7);
    overflow: hidden;
    isolation: isolate;
  }
  .hero__field {
    position: absolute; inset: 0; z-index: -2;
    opacity: 0.9;
  }
  .hero__veil {
    position: absolute; inset: 0; z-index: -1;
    background:
      radial-gradient(120% 80% at 78% 30%, transparent 0%, var(--ink) 72%),
      linear-gradient(180deg, oklch(20% 0.028 168 / 0.2) 0%, var(--ink) 96%);
  }

  .hero__inner { position: relative; }
  .hero__copy { max-width: 46rem; }
  .hero__title {
    font-size: clamp(2.6rem, 1.7rem + 3.6vw, 4.6rem);
    margin-top: var(--sp-4);
    letter-spacing: -0.035em;
    max-width: 18ch;
  }
  .hero__accent { color: var(--jade); }
  .hero__fn { font-size: 0.32em; vertical-align: super; line-height: 0; font-family: var(--font-body); }
  .hero__fn a { color: var(--muted-2); font-weight: 600; }
  .hero__fn a:hover { color: var(--jade); }
  .hero__lede { margin-top: var(--sp-4); max-width: 50ch; }
  .hero__actions {
    margin-top: var(--sp-5);
    display: flex; flex-wrap: wrap; gap: var(--sp-3);
  }
  .hero__trust {
    margin-top: var(--sp-5);
    display: flex; flex-wrap: wrap; gap: var(--sp-3) var(--sp-5);
    color: var(--muted-2); font-size: var(--step--1);
  }
  .hero__trust li { display: flex; align-items: center; gap: 0.5rem; }
  .hero__trust li::before {
    content: ""; width: 6px; height: 6px; border-radius: 50%;
    background: var(--jade); box-shadow: 0 0 8px var(--jade-glow);
  }

  .hero__scroll {
    position: absolute; left: 50%; bottom: 1.6rem; translate: -50% 0;
    width: 26px; height: 42px; border-radius: var(--radius-pill);
    border: 1.5px solid var(--line); display: grid; place-items: start center;
    padding-top: 7px;
  }
  .hero__scroll span {
    width: 4px; height: 8px; border-radius: 4px; background: var(--jade);
    animation: scrolldot 1.8s var(--ease-out-quint) infinite;
  }
  @keyframes scrolldot {
    0% { opacity: 0; transform: translateY(0); }
    30% { opacity: 1; }
    70% { opacity: 1; transform: translateY(12px); }
    100% { opacity: 0; transform: translateY(16px); }
  }
  @media (max-width: 700px) {
    .hero__scroll { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__scroll span { animation: none; }
  }
</style>
