---
const facts = [
  {
    n: 'Fact 01',
    title: 'Genes need functional data',
    body: 'A gene variant only tells you what could happen. Pairing it with real-time biomarkers shows what is happening, so corrections are grounded in your current biochemistry.',
  },
  {
    n: 'Fact 02',
    title: 'One system is never the whole story',
    body: 'Energy, detox, methylation, and gut health all influence each other. Assessing several systems at once is what turns scattered symptoms into a clear root cause.',
  },
  {
    n: 'Fact 03',
    title: 'Ten pills from one test is a gamble',
    body: 'A single marker cannot justify a stack of supplements. Precision means acting on a full picture, not guessing from a fragment.',
  },
];
---

<section class="section section--tight problem">
  <div class="container narrow center">
    <h2 class="problem__title" data-reveal>
      You have seen the ads promising to optimize your health from five genes
      and a supplement list.
    </h2>
    <p class="lede" data-reveal style="--reveal-delay: 0.08s">
      Real precision works differently. Three things separate guidance you can
      trust from a guess in a nicer box.
    </p>
  </div>

  <div class="container">
    <div class="facts" data-stagger>
      {facts.map((f) => (
        <article class="fact">
          <p class="fact__n">{f.n}</p>
          <h3 class="fact__title">{f.title}</h3>
          <p class="prose fact__body">{f.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .problem__title { font-size: var(--step-2); margin: var(--sp-3) auto var(--sp-4); max-width: 24ch; }
  .facts {
    margin-top: var(--sp-7);
    display: grid; gap: var(--sp-4);
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }
  .fact {
    padding: var(--sp-5);
    border-top: 2px solid var(--jade);
    background: linear-gradient(180deg, var(--surface) 0%, var(--ink) 130%);
    border-radius: 0 0 var(--radius) var(--radius);
  }
  .fact__n { font-family: var(--font-display); font-size: var(--step--1); color: var(--jade); font-weight: 600; letter-spacing: 0.02em; }
  .fact__title { font-size: var(--step-1); margin: var(--sp-2) 0 var(--sp-3); }
  .fact__body { color: var(--muted); }
</style>
