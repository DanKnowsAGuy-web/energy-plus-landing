---
const stats = [
  { count: 150, suffix: '+', label: 'biomarkers measured', sub: 'across your functional systems' },
  { count: 6, suffix: '', label: 'physiological categories', sub: 'one connected picture' },
  { count: 0, suffix: '', label: 'lab visits required', sub: 'collected at home' },
];
---

<section class="section" id="what">
  <div class="container narrow center">
    <h2 class="h" data-reveal>
      We read your body first, so you are not guessing.
    </h2>
    <p class="lede" data-reveal style="--reveal-delay: 0.08s">
      Being cautious about GLP-1 is reasonable. This is your body, and most advice is
      built for an average, not for you. Balance Protocol™ GPS starts with NutraCoreX™,
      an at-home array of 150+ functional biomarkers and clinically relevant genetics,
      so the conversation with your clinician begins with real information about you.
    </p>
  </div>

  <div class="container">
    <div class="stats" data-stagger>
      {stats.map((s) => (
        <div class="stat">
          <p class="stat__num">
            <span data-count={s.count}>0</span>{s.suffix}
          </p>
          <p class="stat__label">{s.label}</p>
          <p class="stat__sub">{s.sub}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .h { font-size: var(--step-3); margin: 0 0 var(--sp-4); }
  .stats {
    margin-top: var(--sp-7);
    display: grid; gap: var(--sp-3);
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }
  .stat {
    padding: var(--sp-5);
    background: linear-gradient(180deg, var(--surface) 0%, var(--ink) 140%);
    border: 1px solid var(--line-soft);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lift);
  }
  .stat__num {
    font-family: var(--font-display); font-weight: 600;
    font-size: var(--step-4); line-height: 1; color: var(--jade);
    letter-spacing: -0.04em;
    font-variant-numeric: tabular-nums;
  }
  /* lock-in: the readout flashes as it snaps to its final value */
  .stat__num.locked { animation: statLock 0.55s var(--ease-out-quint); }
  @keyframes statLock {
    0%   { color: var(--jade-strong); text-shadow: 0 0 24px var(--jade-glow); }
    100% { color: var(--jade); text-shadow: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .stat__num.locked { animation: none; }
  }
  .stat__label { margin-top: var(--sp-2); font-weight: 600; color: var(--paper); }
  .stat__sub { color: var(--muted-2); font-size: var(--step--1); }
</style>
