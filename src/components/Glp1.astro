---
import DoseCurve from './DoseCurve.astro';
const pillars = [
  { title: 'Dosage context', body: 'Information about how your physiology may respond, to support a dose conversation with your clinician rather than a default ramp.' },
  { title: 'Timing context', body: 'Your metabolic and nutrient picture, which can help inform when and how dosing fits your routine.' },
  { title: 'Side-effect awareness', body: 'Markers often associated with muscle loss and nutrient depletion, so you and your clinician know what to keep an eye on.' },
  { title: 'Planning ahead', body: 'A clear baseline to revisit over time, useful context for any conversation about adjusting or pausing a course.' },
];
---

<section class="section glp1" id="glp1">
  <div class="container glp1__grid">
    <div class="glp1__copy">
      <p class="eyebrow" data-reveal>How your data informs GLP-1</p>
      <h2 class="glp1__title" data-reveal style="--reveal-delay: 0.06s">
        Four things your results help you and your clinician get right.
      </h2>
      <p class="prose" data-reveal style="--reveal-delay: 0.12s">
        GLP-1 decisions are usually made on dose, timing, side effects, and what happens
        when you stop. Your NutraCoreX™ results give those decisions something concrete to
        stand on: your own biochemistry and genetics, read clearly.
      </p>
      <p class="prose" data-reveal style="--reveal-delay: 0.16s">
        We do not prescribe and we do not replace your provider. We give you and your
        clinician better information to work from.<sup class="glp1__fn"><a href="#disclaimer" aria-label="Read important disclaimer">2</a></sup>
      </p>
      <DoseCurve />
    </div>

    <ul class="glp1__pillars" data-stagger>
      {pillars.map((p) => (
        <li class="pillar">
          <div class="pillar__dot" aria-hidden="true"></div>
          <h3 class="pillar__title">{p.title}</h3>
          <p class="pillar__body">{p.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .glp1 {
    background:
      radial-gradient(80% 120% at 100% 0%, oklch(28% 0.05 162 / 0.7) 0%, transparent 55%),
      var(--ink);
  }
  .glp1__grid { display: grid; gap: var(--sp-6); }
  @media (min-width: 880px) {
    .glp1__grid { grid-template-columns: 1fr 1fr; gap: var(--sp-8); align-items: start; }
    .glp1__copy { position: sticky; top: 96px; }
  }
  .glp1__title { font-size: var(--step-3); margin: var(--sp-3) 0 var(--sp-4); }
  .glp1__fn { font-size: 0.7em; vertical-align: super; line-height: 0; }
  .glp1__fn a { color: var(--jade); font-weight: 600; }

  .glp1__pillars { display: grid; gap: 1px; background: var(--line-soft); border-radius: var(--radius); overflow: hidden; border: 1px solid var(--line-soft); }
  .pillar {
    padding: var(--sp-5);
    background: var(--surface);
    position: relative;
    transition: background var(--dur-2) ease;
  }
  .pillar:hover { background: var(--surface-2); }
  .pillar__dot {
    width: 9px; height: 9px; border-radius: 50%;
    background: var(--jade); box-shadow: 0 0 12px var(--jade-glow);
    margin-bottom: var(--sp-3);
  }
  .pillar__title { font-size: var(--step-1); margin-bottom: var(--sp-2); }
  .pillar__body { color: var(--muted); font-size: var(--step-0); }
  @media (min-width: 520px) {
    .glp1__pillars { grid-template-columns: 1fr 1fr; }
  }
</style>
